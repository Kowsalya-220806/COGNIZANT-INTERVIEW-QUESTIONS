#include <iostream>
using namespace std;
int main() {
    int n;
    if (!(cin >> n)) return 0;
    for (int i = 0; i < n; ++i) {
        int rowLength = n - i;
        char patternChar = (i % 2 == 0) ? '1' : '0';
        for (int j = 0; j < rowLength; ++j) {
            cout << patternChar;
        }
        cout << endl;
    }
    return 0;
}
