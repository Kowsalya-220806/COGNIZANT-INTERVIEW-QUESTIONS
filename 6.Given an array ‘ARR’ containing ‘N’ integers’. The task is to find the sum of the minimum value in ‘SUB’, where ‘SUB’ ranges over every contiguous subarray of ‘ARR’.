#include <iostream>
using namespace std;
int main() {
    int n;
    if (!(cin >> n)) return 0;
    int arr[1000]; 
    for (int i = 0; i < n; ++i) {
        cin >> arr[i];
    }
    long long totalSum = 0;
    for (int i = 0; i < n; ++i) {
        int currentMin = arr[i];
        for (int j = i; j < n; ++j) {
            if (arr[j] < currentMin) {
                currentMin = arr[j];
            }
           
            totalSum += currentMin;
        }
    }
    cout << totalSum << endl;
    return 0;
}
