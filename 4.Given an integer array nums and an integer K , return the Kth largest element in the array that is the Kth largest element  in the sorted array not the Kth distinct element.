#include <iostream>
using namespace std;
int main() {
    int nums[1000];
    int n = 0;
    int temp;
    while (cin >> temp) {
        nums[n++] = temp;
        if (cin.peek() == '\n') {
            break;
        }
    }
    int k;
    cin >> k;
    int topK[100]; 
    int current_size = 0;

    for (int i = 0; i < n; i++) {
        int val = nums[i];
        if (current_size < k) {
            int j = current_size - 1;
            while (j >= 0 && topK[j] > val) {
                topK[j + 1] = topK[j];
                j--;
            }
            topK[j + 1] = val;
            current_size++;
        } 
        else if (val > topK[0]) {
            int j = 1;
            while (j < k && topK[j] < val) {
                topK[j - 1] = topK[j];
                j++;
            }
            topK[j - 1] = val;
        }
    }
    cout << topK[0] << endl;
    return 0;
}
